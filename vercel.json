{
  "crons": [
    {
      "path": "/api/cron/post-threads?slot=morning",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/post-threads?slot=evening",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron/post-products",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/sync-images",
      "schedule": "0 5 * * *"
    }
  ],
  "functions": {
    "api/cron/post-threads.js": {
      "maxDuration": 300
    },
    "api/cron/post-products.js": {
      "maxDuration": 300
    },
    "api/cron/sync-images.js": {
      "maxDuration": 60
    }
  }
}
